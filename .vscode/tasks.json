{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "cmake -S . -B build",
      "problemMatcher": []
    },
    {
      "label": "Build dgmini",
      "type": "shell",
      "command": "cmake --build build --target dgmini",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Build dgmini_unittest",
      "type": "shell",
      "command": "cmake --build build --target dgmini_unittest",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Run dgmini",
      "type": "shell",
      "command": "${workspaceFolder}/build/dgmini",
      "dependsOn": "Build dgmini",
      "problemMatcher": []
    },
    {
      "label": "Run dgmini_unittest",
      "type": "shell",
      "command": "${workspaceFolder}/build/dgmini_unittest",
      "dependsOn": "Build dgmini_unittest",
      "problemMatcher": []
    },
    {
      "label": "Run regression tests",
      "type": "shell",
      "command": "PYTHONDONTWRITEBYTECODE=1 pytest tests/regression -v",
      "dependsOn": "Build dgmini",
      "problemMatcher": []
    },
    {
      "label": "Run all tests",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Run dgmini_unittest",
        "Run regression tests"
      ],
      "problemMatcher": []
    }
    {
      "label": "Count code lines",
      "type": "shell",
      "command": "find source unittest -type f \\( -name \"*.cpp\" -o -name \"*.h\" \\) -exec wc -l {} +",
      "problemMatcher": []
    }
  ]
}